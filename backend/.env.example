# Default: simple local startup with SQLite.
EVIDENT_DATABASE_URL=sqlite:///./data/evident_ai.db
EVIDENT_ALLOWED_ORIGINS=["http://localhost:3002"]
EVIDENT_STORAGE_DIR=storage
EVIDENT_OCR_WORK_DIR=storage/ocr_work
EVIDENT_VISION_OCR_PROVIDER=stub
EVIDENT_VISION_OCR_MAX_IMAGES=3

# Optional AI OCR provider:
# EVIDENT_VISION_OCR_PROVIDER=openai
# EVIDENT_OPENAI_API_KEY=sk-...
# EVIDENT_OPENAI_VISION_MODEL=gpt-4.1-mini

# Optional PostgreSQL example:
# 1. Install a PostgreSQL driver:
#    pip install "psycopg[binary]"
# 2. Replace EVIDENT_DATABASE_URL with:
# EVIDENT_DATABASE_URL=postgresql+psycopg://evident_ai:evident_ai@localhost:5432/evident_ai
